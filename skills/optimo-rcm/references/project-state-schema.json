{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optimoventures.ai/schemas/rcm/project-state",
  "title": "RCM Project State",
  "description": "Canonical schema for the RCM Project State — the central accumulated object of the Recursive Multi-Perspective Reasoning Pattern (Cortex 02.10). 13 canonical dimensions + metadata.",
  "type": "object",
  "required": ["metadata", "objectives", "concepts", "research", "evidence", "assumptions", "decisions", "deliverables", "dependencies", "risks", "constraints", "successCriteria", "feedback", "specifications"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["projectId", "projectName", "created", "updated", "version", "branch", "status"],
      "properties": {
        "projectId": { "type": "string", "description": "Unique project identifier (UUID or slug)" },
        "projectName": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "version": { "type": "integer", "minimum": 1 },
        "branch": { "type": "string", "default": "main" },
        "parentBranch": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["draft", "in-progress", "approved", "archived"] },
        "cortexRef": { "type": "string", "const": "02.10 — Recursive Multi-Perspective Reasoning Pattern" },
        "initiatedBy": { "type": "string" }
      }
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "source"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["primary", "secondary", "constraint"] },
          "priority": { "type": "string", "enum": ["must-have", "should-have", "nice-to-have"] },
          "source": { "type": "string", "enum": ["explorer", "evaluator", "executor", "threat", "social", "user"] },
          "kpi": { "type": "string" }
        }
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "source"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "novelty": { "type": "string", "enum": ["high", "medium", "low"] },
          "origin": { "type": "string", "enum": ["analogy", "cross-domain", "extension", "original"] },
          "source": { "type": "string", "enum": ["explorer", "social"] },
          "evaluation": {
            "type": "object",
            "properties": {
              "score": { "type": "number", "minimum": 0, "maximum": 5 },
              "evaluatedBy": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },
    "research": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "source"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "domain": { "type": "string" },
          "priority": { "type": "string", "enum": ["high", "medium", "low"] },
          "source": { "type": "string", "enum": ["explorer", "evaluator"] },
          "findings": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "in-progress", "resolved"] }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "source", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "claim": { "type": "string" },
          "source": { "type": "string" },
          "sourceUrl": { "type": "string", "format": "uri" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "type": { "type": "string", "enum": ["primary", "secondary", "analyst-estimate"] },
          "date": { "type": "string", "format": "date" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "assumption", "source", "validated"],
        "properties": {
          "id": { "type": "string" },
          "assumption": { "type": "string" },
          "source": { "type": "string", "enum": ["explorer", "evaluator", "executor", "threat", "social"] },
          "validated": { "type": "boolean" },
          "ifFalse": { "type": "string", "description": "What breaks if this assumption is wrong" },
          "validationMethod": { "type": "string" }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "decision", "rationale", "source", "date"],
        "properties": {
          "id": { "type": "string" },
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "alternatives": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string", "enum": ["evaluator", "executor", "social"] },
          "date": { "type": "string", "format": "date-time" },
          "reversible": { "type": "boolean" }
        }
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "spec", "source"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "spec": { "type": "string", "description": "Concrete, buildable description" },
          "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
          "phase": { "type": "string" },
          "source": { "type": "string", "enum": ["executor"] },
          "status": { "type": "string", "enum": ["pending", "in-progress", "complete"] }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "blocks", "source"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "blocks": { "type": "array", "items": { "type": "string" } },
          "resolution": { "type": "string" },
          "source": { "type": "string", "enum": ["executor", "threat"] },
          "status": { "type": "string", "enum": ["unresolved", "in-progress", "resolved"] }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "category", "probability", "impact", "source"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string", "enum": ["technical", "security", "compliance", "market", "execution", "financial", "reputational"] },
          "probability": { "type": "number", "minimum": 0, "maximum": 1 },
          "impact": { "type": "integer", "minimum": 1, "maximum": 5 },
          "pXI": { "type": "number" },
          "mitigation": { "type": "string" },
          "residualRisk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "trigger": { "type": "string" },
          "source": { "type": "string", "enum": ["threat", "evaluator", "social"] }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "type", "source"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["hard", "soft"] },
          "category": { "type": "string", "enum": ["compliance", "technical", "resource", "timeline", "other"] },
          "source": { "type": "string", "enum": ["threat", "social", "executor"] }
        }
      }
    },
    "successCriteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "metric", "threshold", "source"],
        "properties": {
          "id": { "type": "string" },
          "metric": { "type": "string" },
          "threshold": { "type": "string" },
          "rationale": { "type": "string" },
          "source": { "type": "string", "enum": ["evaluator", "social"] }
        }
      }
    },
    "feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "signal", "source", "date"],
        "properties": {
          "id": { "type": "string" },
          "signal": { "type": "string" },
          "type": { "type": "string", "enum": ["positive", "negative", "neutral", "silence"] },
          "stakeholder": { "type": "string" },
          "source": { "type": "string", "enum": ["social"] },
          "date": { "type": "string", "format": "date-time" }
        }
      }
    },
    "specifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "content", "source"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "content": { "type": "string", "description": "Execution-ready specification text" },
          "type": { "type": "string", "enum": ["technical", "creative", "business", "compliance"] },
          "source": { "type": "string", "enum": ["executor"] },
          "approvedBy": {
            "type": "object",
            "properties": {
              "explorer": { "type": "boolean" },
              "evaluator": { "type": "boolean" },
              "executor": { "type": "boolean" },
              "threat": { "type": "boolean" },
              "social": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
